<!--
  Microsoft Purview Rules
  Rule IDs: 108600–108699

  Provides detection for Microsoft Purview audit events ingested
  via the Wazuh Office 365 module or syslog forwarding.

  Microsoft Purview Areas Covered:
    DLP                      — Data Loss Prevention policy matches
    Sensitivity Labels       — Information protection label events
    Insider Risk Management  — Insider risk alerts and investigations
    eDiscovery               — Search, hold, and export activities
    Communication Compliance — Policy matches in communications
    Records Management       — Retention label and disposition events
    Audit                    — Configuration and policy changes
-->

<group name="microsoft_purview,">

  <!-- ===== Base Microsoft Purview Rule (JSON via O365 module) ===== -->

  <rule id="108600" level="3">
    <decoded_as>json</decoded_as>
    <field name="Workload" type="pcre2">(?i)purview|compliance</field>
    <description>Microsoft Purview: $(Operation) event detected.</description>
    <options>no_full_log</options>
    <group>purview_base,</group>
  </rule>

  <!-- ===== Base Microsoft Purview Rule (syslog-forwarded) ===== -->

  <rule id="108601" level="3">
    <decoded_as>microsoft-purview</decoded_as>
    <description>Microsoft Purview: Syslog event detected.</description>
    <options>no_full_log</options>
    <group>purview_base,</group>
  </rule>

  <!-- ===== DLP Events ===== -->

  <rule id="108610" level="10">
    <if_sid>108600</if_sid>
    <field name="Operation" type="pcre2">(?i)DlpRuleMatch</field>
    <description>Microsoft Purview DLP: Policy rule match — $(ExchangeMetaData.Subject).</description>
    <mitre>
      <id>T1048</id>
    </mitre>
    <options>no_full_log</options>
    <group>purview_dlp,data_loss_prevention,</group>
  </rule>

  <rule id="108611" level="12">
