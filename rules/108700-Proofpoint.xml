<!--
  Proofpoint Rules
  Rule IDs: 108700–108799

  Provides detection for Proofpoint email security events ingested
  via a direct API integration (e.g. the Proofpoint TAP API) or
  syslog forwarding.

  Proofpoint Areas Covered:
    Messages             — Blocked and delivered threat messages
    Phishing             — Phishing attempts detected by Proofpoint
    Malware              — Malware attachments and URLs
    Impostor / BEC       — Business Email Compromise and impostor detection
    Click Protection     — Permitted and blocked clicks on malicious URLs
    URL Defence          — URL-based threat detection
    DLP                  — Email Data Loss Prevention events
    Quarantine           — Quarantine actions and releases
    Spam                 — Spam detection events
    Admin / Config       — Administrative and configuration changes
-->

<group name="proofpoint,">

  <!-- ===== Base Proofpoint Rule (JSON via API integration) ===== -->

  <rule id="108700" level="3">
    <decoded_as>json</decoded_as>
    <field name="type" type="pcre2">(?i)^(?:message|click)$</field>
    <field name="guid">\.</field>
    <description>Proofpoint: $(type) event detected.</description>
    <options>no_full_log</options>
    <group>proofpoint_base,</group>
  </rule>

  <!-- ===== Base Proofpoint Rule (syslog-forwarded) ===== -->

  <rule id="108701" level="3">
    <decoded_as>proofpoint</decoded_as>
    <description>Proofpoint: Syslog event detected.</description>
    <options>no_full_log</options>
    <group>proofpoint_base,</group>
  </rule>

  <!-- ===== Message Threat Events ===== -->

  <rule id="108710" level="10">
    <if_sid>108700</if_sid>
    <field name="disposition" type="pcre2">(?i)blocked</field>
    <description>Proofpoint: Threat message blocked — $(subject).</description>
    <mitre>
      <id>T1566</id>
    </mitre>
    <options>no_full_log</options>
    <group>proofpoint_message,email_blocked,</group>
  </rule>

  <rule id="108711" level="12">
    <if_sid>108700</if_sid>
    <field name="disposition" type="pcre2">(?i)delivered</field>
    <field name="threatsInfoMap">\.</field>
    <description>Proofpoint: Threat message delivered — $(subject).</description>
    <mitre>
      <id>T1566</id>
    </mitre>
    <options>no_full_log</options>
    <group>proofpoint_message,email_delivered_threat,</group>
  </rule>

  <rule id="108712" level="8">
    <if_sid>108700</if_sid>
    <field name="disposition" type="pcre2">(?i)quarantined</field>
    <description>Proofpoint: Message quarantined — $(subject).</description>
    <options>no_full_log</options>
    <group>proofpoint_message,email_quarantined,</group>
  </rule>

  <!-- ===== Phishing Events ===== -->

  <rule id="108720" level="10">
    <if_sid>108700</if_sid>
    <field name="classification" type="pcre2">(?i)phish</field>
    <description>Proofpoint: Phishing attempt detected — $(subject).</description>
    <mitre>
      <id>T1566.001</id>
    </mitre>
    <options>no_full_log</options>
    <group>proofpoint_phishing,</group>
  </rule>

  <rule id="108721" level="12">
    <if_sid>108720</if_sid>
    <field name="disposition" type="pcre2">(?i)delivered</field>
    <description>Proofpoint: Phishing message delivered to user — $(subject).</description>
    <mitre>
      <id>T1566.001</id>
    </mitre>
    <options>no_full_log</options>
    <group>proofpoint_phishing,email_delivered_threat,</group>
  </rule>

  <!-- ===== Malware Events ===== -->

  <rule id="108730" level="10">
    <if_sid>108700</if_sid>
    <field name="classification" type="pcre2">(?i)malware</field>
    <description>Proofpoint: Malware detected — $(subject).</description>
    <mitre>
      <id>T1566.001</id>
      <id>T1204.002</id>
    </mitre>
    <options>no_full_log</options>
    <group>proofpoint_malware,</group>
  </rule>

  <rule id="108731" level="14">
    <if_sid>108730</if_sid>
    <field name="disposition" type="pcre2">(?i)delivered</field>
    <description>Proofpoint: Malware delivered to user — $(subject).</description>
    <mitre>
      <id>T1566.001</id>
      <id>T1204.002</id>
    </mitre>
    <options>no_full_log</options>
    <group>proofpoint_malware,email_delivered_threat,</group>
  </rule>

  <!-- ===== Impostor / BEC Events ===== -->

  <rule id="108740" level="12">
    <if_sid>108700</if_sid>
    <field name="classification" type="pcre2">(?i)impostor</field>
    <description>Proofpoint: Impostor/BEC attempt detected — $(subject).</description>
    <mitre>
      <id>T1566.002</id>
      <id>T1534</id>
    </mitre>
    <options>no_full_log</options>
    <group>proofpoint_impostor,</group>
  </rule>

  <rule id="108741" level="14">
    <if_sid>108740</if_sid>
    <field name="disposition" type="pcre2">(?i)delivered</field>
    <description>Proofpoint: Impostor/BEC message delivered to user — $(subject).</description>
    <mitre>
      <id>T1566.002</id>
      <id>T1534</id>
    </mitre>
    <options>no_full_log</options>
    <group>proofpoint_impostor,email_delivered_threat,</group>
  </rule>

  <!-- ===== Click Protection Events ===== -->

  <rule id="108750" level="8">
    <if_sid>108700</if_sid>
    <field name="type" type="pcre2">(?i)click</field>
    <field name="disposition" type="pcre2">(?i)blocked</field>
    <description>Proofpoint: Malicious URL click blocked — $(url).</description>
    <mitre>
      <id>T1204.001</id>
    </mitre>
    <options>no_full_log</options>
    <group>proofpoint_click,url_blocked,</group>
  </rule>

  <rule id="108751" level="12">
    <if_sid>108700</if_sid>
    <field name="type" type="pcre2">(?i)click</field>
    <field name="disposition" type="pcre2">(?i)permitted</field>
    <description>Proofpoint: User clicked malicious URL — $(url).</description>
    <mitre>
      <id>T1204.001</id>
    </mitre>
    <options>no_full_log</options>
    <group>proofpoint_click,url_permitted,</group>
  </rule>

  <!-- ===== Spam Events ===== -->

  <rule id="108760" level="3">
    <if_sid>108700</if_sid>
    <field name="classification" type="pcre2">(?i)spam</field>
    <description>Proofpoint: Spam detected — $(subject).</description>
    <options>no_full_log</options>
    <group>proofpoint_spam,</group>
  </rule>

  <rule id="108761" level="5">
    <if_sid>108760</if_sid>
    <field name="disposition" type="pcre2">(?i)delivered</field>
    <description>Proofpoint: Spam message delivered to user — $(subject).</description>
    <options>no_full_log</options>
    <group>proofpoint_spam,email_delivered_threat,</group>
  </rule>

  <!-- ===== DLP Events ===== -->

  <rule id="108770" level="10">
    <if_sid>108700</if_sid>
    <field name="classification" type="pcre2">(?i)dlp</field>
    <description>Proofpoint DLP: Policy violation detected — $(subject).</description>
    <mitre>
      <id>T1048</id>
    </mitre>
    <options>no_full_log</options>
    <group>proofpoint_dlp,data_loss_prevention,</group>
  </rule>

  <rule id="108771" level="12">
    <if_sid>108770</if_sid>
    <field name="disposition" type="pcre2">(?i)blocked</field>
    <description>Proofpoint DLP: Message blocked by DLP policy — $(subject).</description>
    <mitre>
      <id>T1048</id>
    </mitre>
    <options>no_full_log</options>
    <group>proofpoint_dlp,data_loss_prevention,email_blocked,</group>
  </rule>

  <!-- ===== Quarantine Events ===== -->

  <rule id="108780" level="5">
    <if_sid>108700</if_sid>
    <match type="pcre2">"action"\s*:\s*"(?i)quarantine"</match>
    <description>Proofpoint: Message moved to quarantine — $(subject).</description>
    <options>no_full_log</options>
    <group>proofpoint_quarantine,</group>
  </rule>

  <rule id="108781" level="8">
    <if_sid>108700</if_sid>
    <match type="pcre2">"action"\s*:\s*"(?i)released"</match>
    <description>Proofpoint: Message released from quarantine — $(subject).</description>
    <mitre>
      <id>T1562.001</id>
    </mitre>
    <options>no_full_log</options>
    <group>proofpoint_quarantine,quarantine_release,</group>
  </rule>

  <!-- ===== Admin and Configuration Events ===== -->

  <rule id="108790" level="5">
    <if_sid>108700</if_sid>
    <match type="pcre2">"action"\s*:\s*"(?i)policyChanged"</match>
    <description>Proofpoint: Security policy modified.</description>
    <mitre>
      <id>T1562.001</id>
    </mitre>
    <options>no_full_log</options>
    <group>proofpoint_admin,policy_change,</group>
  </rule>

  <rule id="108791" level="10">
    <if_sid>108700</if_sid>
    <match type="pcre2">"action"\s*:\s*"(?i)policyRemoved"</match>
    <description>Proofpoint: Security policy removed.</description>
    <mitre>
      <id>T1562.001</id>
    </mitre>
    <options>no_full_log</options>
    <group>proofpoint_admin,policy_change,</group>
  </rule>

  <rule id="108792" level="10">
    <if_sid>108700</if_sid>
    <match type="pcre2">"action"\s*:\s*"(?i)allowListModified"</match>
    <description>Proofpoint: Allow list modified.</description>
    <mitre>
      <id>T1562.001</id>
    </mitre>
    <options>no_full_log</options>
    <group>proofpoint_admin,policy_change,</group>
  </rule>

</group>
