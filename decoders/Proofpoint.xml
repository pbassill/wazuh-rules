<!--
  Proofpoint Decoder

  Parses Proofpoint email security events forwarded via syslog.
  When logs are ingested through a direct API integration (e.g. the
  Proofpoint TAP API) they arrive as JSON and the built-in json
  decoder handles them automatically, so this decoder is only needed
  for syslog-forwarded Proofpoint events.

  Expected syslog format:
    <timestamp> <host> Proofpoint: {"type":"message","guid":"...","sender":"...","recipient":"...","subject":"...","disposition":"...",...}
-->

<!-- Base decoder: match the program name -->
<decoder name="proofpoint">
  <program_name>Proofpoint</program_name>
</decoder>

<!-- Extract the JSON payload that follows the program name -->
<decoder name="proofpoint">
  <parent>proofpoint</parent>
  <regex type="pcre2">(\{.+\})</regex>
  <order>proofpoint_payload</order>
</decoder>
